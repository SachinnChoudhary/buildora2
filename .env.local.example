# ⚠️ IMPORTANT: NEVER commit .env.local to Git!
# Add .env.local to .gitignore
# This file is .env.local.example - rename to .env.local and fill in your actual values

# Firebase Web App Configuration (PUBLIC - OK to have in .env.local.example as placeholders)
# Get these from: Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your-app-id:web:your-web-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-YOUR-ANALYTICS-ID

# Firebase Admin SDK Configuration (PRIVATE - NEVER commit real values!)
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# ⚠️ KEEP THESE SECRET - DO NOT SHARE OR COMMIT
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Stripe Configuration (Legacy)
# Get these from: Stripe Dashboard → API Keys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# PhonePe Configuration (Payment Gateway)
# Get these from: PhonePe Merchant Dashboard
PHONEPE_MERCHANT_ID=PGTESTPAYUAT
PHONEPE_SALT_KEY=099eb0cd-02cf-4e2a-8aca-3e6c6aff0399
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT # Use 'PROD' for production

# Application Base URL
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Deployment Environment
# NODE_ENV=development

