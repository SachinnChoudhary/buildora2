rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Is the user an admin? (Stored in their user document)
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Is the user the owner of the document?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true; 
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Projects Collection (Marketplace)
    match /projects/{projectId} {
      allow read: if true; // Public listings
      allow create: if isAuthenticated() && isAdmin(); // Only admins can create official projects
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // Project Requests (Custom requests or purchase intents)
    match /project_requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.requesterId || 
        request.auth.uid == resource.data.ownerId ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerId || 
        request.auth.uid == resource.data.requesterId ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated(); 
      allow update, delete: if isAuthenticated() && isAdmin();
    // Diagnostic / Health Checks
    match /system_checks/{docId} {
      allow read, write: if isAuthenticated() && isAdmin();
    }
  }
}
